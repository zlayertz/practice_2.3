import tkinter as tk
from tkinter import ttk, messagebox
import requests
window = tk.Tk()
window.title('Проверка сайтов')
window.geometry('700x200')
window.configure(bg='lightgray')
sites = ['https://github.com/', 'https://www.binance.com/en', 'https://tomtit.tomsk.ru/', 'https://jsonplaceholder.typicode.com/', 'https://moodle.tomtit-tomsk.ru/']
def check():
    for item in table.get_children():
        table.delete(item)
    for site in sites:
        try:
            otvet = requests.get(site, timeout=10)
            if otvet.status_code == 200:
                status = 'Доступен'
            elif otvet.status_code == 403:
                status = 'Доступ запрещен'
            elif otvet.status_code == 404:
                status = 'Не найден'
            else:
                status = 'Не доступен'
            table.insert('', tk.END, values=(site, status, otvet.status_code))
        except:
            table.insert('', tk.END, values=(site, 'Не доступен', 'Ошибка'))
    messagebox.showinfo('Готово', 'Программа завершилась')
button = tk.Button(window, text='Проверить сайты', command=check, bg='green', fg='white', padx=20, pady=8)
button.pack(pady=10)
table = ttk.Treeview(window, columns=('url', 'status', 'code'), show='headings')
table.heading('url', text='Ссылки на сайты')
table.heading('status', text='Статус')
table.heading('code', text='Код')
table.column('url', width=400)
table.column('status', width=120)
table.column('code', width=100)
table.pack(fill=tk.BOTH, expand=True, padx=10, pady=10)
window.mainloop()
